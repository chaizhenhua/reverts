{
  "tool": "esbuild",
  "version": "0.28.0",
  "command": [
    "npx",
    "--yes",
    "esbuild@0.28.0",
    "input/entry.js",
    "--bundle",
    "--alias:@abs-path/pkg6=input/alias6/dir",
    "--alias:@abs-path/pkg7=input/alias7/dir",
    "--alias:@scope-only=input/alias8/dir",
    "--alias:@scope/pkg4=input/node_modules/alias4",
    "--alias:@scope/pkg5=input/node_modules/alias5",
    "--alias:@scope/prefix=alias11",
    "--alias:pkg1=input/node_modules/alias1",
    "--alias:pkg2=input/node_modules/alias2",
    "--alias:pkg3=input/node_modules/alias3",
    "--alias:prefix=alias10",
    "--alias:slash=input/alias9/some/file.js",
    "--outfile=artifacts/esbuild@0.28.0/out.js"
  ],
  "entry_points": [
    "input/entry.js"
  ],
  "advanced_entry_points": null,
  "options": {
    "mode": "bundle",
    "bundle": true,
    "format": null,
    "platform": null,
    "target": null,
    "conditions": [],
    "abs_node_paths": [],
    "supported": null,
    "abs_working_dir": null,
    "code_splitting": false,
    "external": [],
    "external_packages": false,
    "loader": {},
    "resolve_extensions": null,
    "out_extension_js": null,
    "source_map": false,
    "js_banner": null,
    "tsconfig_path": null,
    "original_target_env": null,
    "abs_output_base": null,
    "public_path": null,
    "entry_names": null,
    "chunk_names": null,
    "asset_names": null,
    "mangle_props": null,
    "reserve_props": null,
    "mangle_quoted": null,
    "drop_labels": [],
    "ignore_dce_annotations": false,
    "keep_names": false,
    "tree_shaking": null,
    "global_name": null,
    "main_fields": null,
    "legal_comments": null,
    "inject_paths": [],
    "package_aliases": {
      "pkg1": "alias1",
      "pkg2": "alias2",
      "pkg3": "alias3",
      "@scope/pkg4": "alias4",
      "@scope/pkg5": "alias5",
      "@abs-path/pkg6": "/alias6/dir",
      "@abs-path/pkg7": "/alias7/dir",
      "@scope-only": "/alias8/dir",
      "slash": "/alias9/some/file.js",
      "prefix": "alias10",
      "@scope/prefix": "alias11"
    },
    "line_limit": null,
    "defines": null,
    "ts": {
      "useDefineForClassFields": null
    },
    "jsx": {
      "factory": null,
      "fragment": null,
      "parse": false,
      "preserve": false,
      "automatic": false,
      "importSource": null,
      "development": false,
      "sideEffects": false,
      "mode": null
    },
    "minify_syntax": false,
    "minify_identifiers": false,
    "minify_whitespace": false,
    "stable_entry_names": false,
    "stable_chunk_names": false
  }
}
