{
  "tool": "esbuild",
  "version": "0.28.0",
  "command": [
    "npx",
    "--yes",
    "esbuild@0.28.0",
    "input/entry.jsx",
    "--bundle",
    "--jsx=automatic",
    "--external:react/jsx-runtime",
    "--outfile=artifacts/esbuild@0.28.0/out.js"
  ],
  "entry_points": [
    "input/entry.jsx"
  ],
  "options": {
    "mode": "bundle",
    "bundle": true,
    "format": null,
    "platform": null,
    "target": null,
    "supported": null,
    "code_splitting": false,
    "external": [
      "react/jsx-runtime"
    ],
    "loader": {},
    "abs_output_base": null,
    "public_path": null,
    "entry_names": null,
    "chunk_names": null,
    "asset_names": null,
    "jsx": {
      "factory": null,
      "fragment": null,
      "parse": false,
      "preserve": false,
      "automatic": true,
      "importSource": null,
      "development": false,
      "sideEffects": false,
      "mode": "automatic"
    },
    "minify_syntax": false,
    "minify_identifiers": false,
    "minify_whitespace": false,
    "stable_entry_names": false,
    "stable_chunk_names": false
  }
}
