{
  "tool": "esbuild",
  "version": "0.28.0",
  "command": [
    "npx",
    "--yes",
    "esbuild@0.28.0",
    "input/a.ts",
    "input/b.ts",
    "--minify-syntax",
    "--minify-identifiers",
    "--minify-whitespace",
    "--supported:logical-assignment=false",
    "--outdir=artifacts/esbuild@0.28.0",
    "--outbase=input",
    "--entry-names=[dir]/[name]"
  ],
  "entry_points": [
    "input/a.ts",
    "input/b.ts"
  ],
  "options": {
    "mode": "passthrough",
    "bundle": false,
    "format": null,
    "platform": null,
    "target": null,
    "supported": {
      "logical-assignment": false
    },
    "code_splitting": false,
    "external": [],
    "loader": {},
    "abs_output_base": null,
    "public_path": null,
    "entry_names": null,
    "chunk_names": null,
    "asset_names": null,
    "jsx": {
      "factory": null,
      "fragment": null,
      "parse": false,
      "preserve": false,
      "automatic": false,
      "importSource": null,
      "development": false,
      "sideEffects": false,
      "mode": null
    },
    "minify_syntax": true,
    "minify_identifiers": true,
    "minify_whitespace": true,
    "stable_entry_names": true,
    "stable_chunk_names": false
  }
}
