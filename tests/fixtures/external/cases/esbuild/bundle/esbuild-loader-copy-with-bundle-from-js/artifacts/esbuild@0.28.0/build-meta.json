{
  "tool": "esbuild",
  "version": "0.28.0",
  "command": [
    "npx",
    "--yes",
    "esbuild@0.28.0",
    "input/Users/user/project/src/entry.js",
    "--bundle",
    "--loader:.js=js",
    "--loader:.file=copy",
    "--outdir=artifacts/esbuild@0.28.0",
    "--outbase=input/Users/user/project",
    "--entry-names=[dir]/[name]"
  ],
  "entry_points": [
    "input/Users/user/project/src/entry.js"
  ],
  "options": {
    "mode": "bundle",
    "bundle": true,
    "format": null,
    "platform": null,
    "target": null,
    "supported": null,
    "code_splitting": false,
    "external": [],
    "loader": {
      ".js": "js",
      ".file": "copy"
    },
    "abs_output_base": "/Users/user/project",
    "public_path": null,
    "entry_names": null,
    "chunk_names": null,
    "asset_names": null,
    "jsx": {
      "factory": null,
      "fragment": null,
      "parse": false,
      "preserve": false,
      "automatic": false,
      "importSource": null,
      "development": false,
      "sideEffects": false,
      "mode": null
    },
    "minify_syntax": false,
    "minify_identifiers": false,
    "minify_whitespace": false,
    "stable_entry_names": true,
    "stable_chunk_names": false
  }
}
