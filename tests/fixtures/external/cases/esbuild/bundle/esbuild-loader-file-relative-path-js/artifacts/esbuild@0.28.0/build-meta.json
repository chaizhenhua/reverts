{
  "tool": "esbuild",
  "version": "0.28.0",
  "command": [
    "npx",
    "--yes",
    "esbuild@0.28.0",
    "input/src/entries/entry.js",
    "--bundle",
    "--loader:.js=js",
    "--loader:.png=file",
    "--outdir=artifacts/esbuild@0.28.0",
    "--outbase=input/src",
    "--entry-names=[dir]/[name]"
  ],
  "entry_points": [
    "input/src/entries/entry.js"
  ],
  "options": {
    "mode": "bundle",
    "bundle": true,
    "format": null,
    "platform": null,
    "target": null,
    "supported": null,
    "code_splitting": false,
    "external": [],
    "loader": {
      ".js": "js",
      ".png": "file"
    },
    "abs_output_base": "/src",
    "public_path": null,
    "entry_names": null,
    "chunk_names": null,
    "asset_names": null,
    "jsx": {
      "factory": null,
      "fragment": null,
      "parse": false,
      "preserve": false,
      "automatic": false,
      "importSource": null,
      "development": false,
      "sideEffects": false,
      "mode": null
    },
    "minify_syntax": false,
    "minify_identifiers": false,
    "minify_whitespace": false,
    "stable_entry_names": true,
    "stable_chunk_names": false
  }
}
