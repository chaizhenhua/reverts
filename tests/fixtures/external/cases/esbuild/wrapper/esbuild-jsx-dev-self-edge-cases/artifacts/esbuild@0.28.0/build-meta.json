{
  "tool": "esbuild",
  "version": "0.28.0",
  "command": [
    "npx",
    "--yes",
    "esbuild@0.28.0",
    "input/*",
    "--bundle",
    "--jsx=automatic",
    "--jsx-dev",
    "--external:react/jsx-dev-runtime",
    "--supported:class-static-field=false",
    "--outdir=artifacts/esbuild@0.28.0",
    "--outbase=input",
    "--entry-names=[dir]/[name]"
  ],
  "entry_points": [
    "input/*"
  ],
  "options": {
    "mode": "bundle",
    "bundle": true,
    "format": null,
    "platform": null,
    "target": null,
    "supported": {
      "class-static-field": false
    },
    "code_splitting": false,
    "external": [
      "react/jsx-dev-runtime"
    ],
    "loader": {},
    "abs_output_base": null,
    "public_path": null,
    "entry_names": null,
    "chunk_names": null,
    "asset_names": null,
    "jsx": {
      "factory": null,
      "fragment": null,
      "parse": false,
      "preserve": false,
      "automatic": true,
      "importSource": null,
      "development": true,
      "sideEffects": false,
      "mode": "automatic"
    },
    "minify_syntax": false,
    "minify_identifiers": false,
    "minify_whitespace": false,
    "stable_entry_names": true,
    "stable_chunk_names": false
  }
}
