{
  "tool": "rollup",
  "version": "4.60.1",
  "source_ref": "test/chunking-form/samples/external-reexports",
  "config_kind": "sample",
  "input": [
    "main-default.js",
    "main-named.js",
    "main-namespace.js"
  ],
  "external": [
    "external-all",
    "external-default",
    "external-default-named",
    "external-default-namespace",
    "external-named",
    "external-namespace",
    "external-named-namespace"
  ],
  "output": {
    "format": "es",
    "preserve_modules": false,
    "preserve_entry_signatures": null,
    "exports": null,
    "entry_file_names": "[name].js",
    "chunk_file_names": "chunks/[name].js"
  },
  "command": [
    "node",
    "-e",
    "rollup(input).write(output)",
    "# source=test/chunking-form/samples/external-reexports"
  ]
}
