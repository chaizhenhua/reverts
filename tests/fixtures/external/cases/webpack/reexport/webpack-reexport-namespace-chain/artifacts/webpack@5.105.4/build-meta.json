{
  "tool": "webpack",
  "version": "5.105.4",
  "source_ref": "test/configCases/code-generation/re-export-namespace",
  "command": [
    "node",
    "-e",
    "webpack(config)",
    "# source=test/configCases/code-generation/re-export-namespace"
  ],
  "config_kind": "config",
  "entry": "./index.js",
  "target": "async-node",
  "mode": "production",
  "output": {
    "filename": "bundle.js",
    "chunk_filename": "chunks/[name].js"
  },
  "experiments": {
    "topLevelAwait": true
  },
  "optimization": {
    "concatenateModules": false,
    "usedExports": true,
    "providedExports": true,
    "minimize": false,
    "mangleExports": false
  }
}
