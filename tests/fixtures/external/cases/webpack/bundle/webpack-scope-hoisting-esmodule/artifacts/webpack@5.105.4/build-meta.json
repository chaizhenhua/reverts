{
  "tool": "webpack",
  "version": "5.105.4",
  "source_ref": "test/configCases/scope-hoisting/esModule",
  "command": [
    "node",
    "-e",
    "webpack(config)",
    "# source=test/configCases/scope-hoisting/esModule"
  ],
  "config_kind": "config",
  "entry": "./index.js",
  "target": "async-node",
  "mode": "development",
  "output": {
    "filename": "bundle.js",
    "chunk_filename": "chunks/[name].js"
  },
  "experiments": {
    "topLevelAwait": true
  },
  "optimization": {
    "concatenateModules": true,
    "minimize": false
  }
}
